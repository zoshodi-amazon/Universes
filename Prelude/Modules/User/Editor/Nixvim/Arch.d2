# Nixvim: Capability-Indexed Plugin Architecture

direction: down

title: {
  label: "Nixvim Plugins (Capability → Rendering Target)"
  shape: text
  style.font-size: 20
}

# ═══════════════════════════════════════
# RENDERING TARGET CATEGORIES
# ═══════════════════════════════════════

Chrome: {
  label: "Chrome/ (Editor Decoration)"
  style.fill: "#88c0d0"
  
  lualine: "statusline"
  bufferline: "tab bar"
  which-key: "key hints"
  devicons: "file icons"
  indent: "indent guides"
  zen: "focus mode"
}

Inline: {
  label: "Inline/ (In-Buffer Rendering)"
  style.fill: "#a3be8c"
  
  image: "image.nvim → terminal images"
  glow: "glow → terminal markdown"
  d2: "d2-vim → ASCII diagrams"
}

Render: {
  label: "Render/ (External Browser Rendering)"
  style.fill: "#81a1c1"
  style.stroke: "#5e81ac"
  style.stroke-width: 3
  
  sidecar: {
    label: "Go Sidecar (Drv/asset-preview)"
    style.fill: "#5e81ac"
    
    http: "HTTP :9876"
    ws: "WebSocket broadcast"
    convert: "Auto-convert (ffmpeg/assimp/pandoc/...)"
  }
  
  frontend: {
    label: "Browser Frontend"
    style.fill: "#4c566a"
    
    images: "2D: <img>"
    models: "3D: three.js (GLB/OBJ/STL + orbit/wireframe/normals)"
    scenes: "Scene: three.js + TransformControls"
    audio: "Audio: wavesurfer.js"
    video: "Video: <video>"
    shaders: "Shaders: glslCanvas"
    docs: "Docs: marked.js / PDF"
    data: "Data: table / highlight"
    fonts: "Fonts: @font-face specimen"
  }
  
  live-server: "live-server.nvim → HTML hot reload"
  md-preview: "markdown-preview → browser markdown"
  
  nvim: {
    label: "Lua Plugin"
    style.fill: "#4c566a"
    autocmd: "BufEnter → POST /preview → WS broadcast"
  }
}

Render.nvim -> Render.sidecar: "curl POST"
Render.sidecar.ws -> Render.frontend: "WebSocket"

# ═══════════════════════════════════════
# CODE INTELLIGENCE CATEGORIES
# ═══════════════════════════════════════

Completion: {
  label: "Completion/"
  style.fill: "#ebcb8b"
  cmp: "nvim-cmp"
}

Languages: {
  label: "Languages/"
  style.fill: "#d08770"
  nix: ".nix → nil LSP"
  lean: ".lean → lean.nvim"
  python: ".py → pyright"
  rust: ".rs → rust-analyzer"
  ts: ".ts → tsserver"
}

Data: {
  label: "Data/"
  style.fill: "#ebcb8b"
  json: ".json → jq"
  yaml: ".yaml → yq"
  csv: ".csv → table"
  toml: ".toml → taplo"
}

Navigation: {
  label: "Navigation/"
  style.fill: "#bf616a"
  telescope: "fuzzy finder"
  oil: "file browser"
  harpoon: "bookmarks"
}

Git: {
  label: "Git/"
  style.fill: "#b48ead"
  signs: "gitsigns"
}

Nix: {
  label: "Nix/"
  style.fill: "#a3be8c"
  lsp: "nil LSP"
}

# ═══════════════════════════════════════
# FLOW
# ═══════════════════════════════════════

Chrome -> Instances
Inline -> Instances
Render -> Instances
Completion -> Instances
Languages -> Instances
Data -> Instances
Navigation -> Instances
Git -> Instances
Nix -> Instances

Instances: {
  label: "Instances/"
  shape: cylinder
  style.fill: "#b48ead"
}

Instances -> target

target: {
  label: "programs.nixvim"
  shape: cylinder
}

# ═══════════════════════════════════════
# DECISION TREE
# ═══════════════════════════════════════

decision: {
  label: "Category Decision Tree"
  style.stroke-dash: 3
  style.fill: "#2e3440"
  
  q1: "Changes editor UI?" {shape: diamond}
  q2: "Renders in buffer?" {shape: diamond}
  q3: "Renders externally?" {shape: diamond}
  
  q1 -> Chrome: "YES"
  q1 -> q2: "NO"
  q2 -> Inline: "YES"
  q2 -> q3: "NO"
  q3 -> Render: "YES"
}
