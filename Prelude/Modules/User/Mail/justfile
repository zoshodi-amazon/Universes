# Mail — CLI mail management via himalaya + posting
#
# Naming: [io-]nix-mail[-subcommand]
#   nix-mail-*    = pure (list, read, search — read-only)
#   io-nix-mail-* = effectful (send, configure — writes state)

# Show typed option space for mail accounts
nix-mail-options:
    @gum style --border normal --padding "0 1" "NixMail Options"
    @echo "mail.enable         : bool                              (default: true)"
    @echo "mail.defaultAccount : str                               (default: \"outlook\")"
    @echo "mail.accounts.<name>:"
    @echo "  email       : str                                     — account email address"
    @echo "  backend     : enum [ imap maildir notmuch ]           (default: imap)"
    @echo "  sendBackend : enum [ smtp sendmail ]                  (default: smtp)"
    @echo "  host        : str                                     (default: outlook.office365.com)"
    @echo "  sendHost    : str                                     (default: smtp-mail.outlook.com)"
    @echo "  auth        : enum [ sops keyring command ]           (default: sops)"

# List envelopes
# ARGS: account - account name (optional, uses default)
nix-mail account="":
    himalaya envelope list {{ if account != "" { "--account " + account } else { "" } }}

# Read a message by ID
# ARGS: id - envelope ID, account - account name (optional)
nix-mail-read id account="":
    himalaya message read {{id}} {{ if account != "" { "--account " + account } else { "" } }}

# Search recent subjects (2FA code extraction)
# ARGS: account - account name (optional), count - number of recent envelopes (default: 5)
nix-mail-2fa account="" count="5":
    himalaya envelope list --output json {{ if account != "" { "--account " + account } else { "" } }} \
      | jq -r '.[0:{{count}}] | .[].subject'

# Send a message (opens $EDITOR)
# ARGS: account - account name (optional)
io-nix-mail-send account="":
    himalaya message write {{ if account != "" { "--account " + account } else { "" } }}

# Configure/reconfigure an account (interactive OAuth2 flow)
# ARGS: name - account name to configure
io-nix-mail-configure name:
    himalaya account configure {{name}}
