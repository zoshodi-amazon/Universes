# Servers Architecture
# Dependency flow: Apps --> Infra --> Data --> Containers

direction: right

Containers: {
  shape: rectangle
  label: "Containers\n(podman | arion)"
}

Data: {
  shape: rectangle
  label: "Data\nPersistence, ObjectStore,\nRelational, Documents,\nRegistry, Backup"
}

Infra: {
  shape: rectangle
  label: "Infra\nGateway, Identity,\nDNS, Metrics, Secrets"
}

Apps: {
  shape: rectangle
  label: "Apps\nGit, Media, LLM, Chat"
}

Apps -> Infra: "auth, routing"
Apps -> Data: "storage"
Infra -> Data: "config"
Data -> Containers: "runtime"
