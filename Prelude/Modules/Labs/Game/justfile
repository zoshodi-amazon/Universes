# ===============================================================================
# GAME DESIGN LAB - Compositional Design Workstation
# ===============================================================================
#
# NAME
#     justfile - 2D pixel art, 3D modeling, audio, simulation, fabrication
#
# SYNOPSIS
#     just <recipe> [arguments...]
#     just --list
#
# DESCRIPTION
#     Terminal-native design lab. Live preview via chafa (kitty protocol).
#     All tools run headless/CLI. No GUI required.
#
#     CORE        - Init, status
#     SPRITE      - 2D pixel art (create, sheet, animate)
#     RENDER      - 2D/3D rendering (imagemagick, blender headless)
#     PREVIEW     - Live terminal/browser preview (chafa + watchexec)
#     AUDIO       - Tone, play, spectrum (ffmpeg)
#     SIMULATE    - Physics simulation (blender headless)
#     FABRICATE   - 3D print export (STL/3MF, slicing)
#     ASSET       - Fetch, list, catalog
#
# ===============================================================================

scripts := "Universe"
lab := ".lab"

default:
    @just --list

# -------------------------------------------------------------------------------
# CORE
# -------------------------------------------------------------------------------

# Initialize workspace
init:
    @nu {{scripts}}/Core/Bindings/Scripts/default.nu '{"action": "init", "projectDir": "{{lab}}"}'

# Show workspace status
status:
    @gum style --border normal --padding "0 1" "Game Lab Status"
    @nu {{scripts}}/Core/Bindings/Scripts/default.nu '{"action": "status", "projectDir": "{{lab}}"}'

# -------------------------------------------------------------------------------
# SPRITE (2D pixel art)
# -------------------------------------------------------------------------------

# Create a blank sprite
# ARGS: name - sprite name, w - width px, h - height px
sprite-create name w="16" h="16":
    @gum style --border normal --padding "0 1" "Creating sprite $(gum style --foreground 212 '{{name}}') {{w}}x{{h}}"
    @nu {{scripts}}/Sprite/Bindings/Scripts/default.nu '{"action": "create", "name": "{{name}}", "width": {{w}}, "height": {{h}}, "output": "{{lab}}/sprites/{{name}}.png"}'
    @just show {{lab}}/sprites/{{name}}.png

# Assemble sprite sheet from frames
# ARGS: name - sprite name, frames - number of frames
sprite-sheet name frames="4":
    @gum style --border normal --padding "0 1" "Assembling sheet for $(gum style --foreground 212 '{{name}}') ({{frames}} frames)"
    @nu {{scripts}}/Sprite/Bindings/Scripts/default.nu '{"action": "sheet", "name": "{{lab}}/sprites/{{name}}", "frames": {{frames}}, "output": "{{lab}}/sprites/{{name}}_sheet.png"}'

# Create animated GIF from sprite frames
# ARGS: name - sprite name, delay - frame delay (1/100s)
sprite-animate name delay="10":
    @gum style --border normal --padding "0 1" "Animating $(gum style --foreground 212 '{{name}}')"
    @nu {{scripts}}/Sprite/Bindings/Scripts/default.nu '{"action": "animate", "name": "{{lab}}/sprites/{{name}}", "delay": {{delay}}, "output": "{{lab}}/sprites/{{name}}.gif"}'

# Scale sprite with nearest-neighbor (pixel-perfect)
# ARGS: input - source file, output - dest file, scale - e.g. 400%
pixel-scale input output scale="400%":
    @nu {{scripts}}/Render/Bindings/Scripts/default.nu '{"action": "pixel-scale", "input": "{{input}}", "output": "{{output}}", "scale": "{{scale}}"}'
    @just show {{output}}

# -------------------------------------------------------------------------------
# RENDER
# -------------------------------------------------------------------------------

# Render 2D image (resize/resample)
# ARGS: input - source, output - dest, res - resolution
render-2d input output=".lab/renders/latest.png" res="320x240":
    @nu {{scripts}}/Render/Bindings/Scripts/default.nu '{"action": "render-2d", "input": "{{input}}", "output": "{{output}}", "resolution": "{{res}}"}'
    @just show {{output}}

# Render 3D scene via blender headless
# ARGS: script - python script for blender, output - render output
render-3d script output=".lab/renders/latest.png" res="1920x1080":
    @gum spin --spinner dot --title "Rendering 3D..." -- nu {{scripts}}/Render/Bindings/Scripts/default.nu '{"action": "render-3d", "input": "{{script}}", "output": "{{output}}", "resolution": "{{res}}"}'
    @just show {{output}}

# -------------------------------------------------------------------------------
# PREVIEW
# -------------------------------------------------------------------------------

# Show image in terminal (iTerm2 imgcat or chafa fallback)
# ARGS: file - image to display
show file:
    @if command -v imgcat > /dev/null 2>&1; then imgcat {{file}}; elif [ -f /Applications/iTerm.app/Contents/Resources/utilities/imgcat ]; then /Applications/iTerm.app/Contents/Resources/utilities/imgcat {{file}}; else chafa --size 60x30 {{file}}; fi

# Live preview - watches file or dir, re-displays on change
# ARGS: target - file or directory to watch
preview target=".lab":
    @echo "Live Preview (Ctrl+C to stop)"
    @watchexec -w {{target}} --exts png,gif,jpg,bmp -- bash -c 'clear; if [ -f /Applications/iTerm.app/Contents/Resources/utilities/imgcat ]; then /Applications/iTerm.app/Contents/Resources/utilities/imgcat {{target}}/sprites/latest.png 2>/dev/null || /Applications/iTerm.app/Contents/Resources/utilities/imgcat {{target}}; else chafa --size 60x30 {{target}}; fi'

# Live edit loop: watches a draw script, re-renders + displays on save
# ARGS: script - .nu file with magick commands, output - render target
live script=".lab/draw.nu" output=".lab/renders/latest.png":
    #!/usr/bin/env nu
    mkdir .lab/renders
    let script: string = "{{script}}"
    let output: string = "{{output}}"
    ["Watching" $script "(Ctrl+C to stop)"] | str join " " | print
    mut last: string = ""
    loop {
      let current: string = (ls $script | get 0.modified | into string)
      if $current != $last {
        $last = $current
        nu $script $output
        ^/Applications/iTerm.app/Contents/Resources/utilities/imgcat $output
      }
      sleep 500ms
    }

# -------------------------------------------------------------------------------
# AUDIO
# -------------------------------------------------------------------------------

# Generate a tone
# ARGS: freq - Hz, duration - seconds, output - file path
audio-tone freq="440" duration="1" output=".lab/audio/tone.wav":
    @mkdir -p .lab/audio
    @gum style --border normal --padding "0 1" "Generating $(gum style --foreground 212 '{{freq}}Hz') tone"
    @ffmpeg -y -loglevel error -f lavfi -i "sine=frequency={{freq}}:duration={{duration}}" {{output}}
    @gum style --foreground 82 "Created: {{output}}"

# Generate noise
# ARGS: duration - seconds, output - file path
audio-noise duration="1" output=".lab/audio/noise.wav":
    @mkdir -p .lab/audio
    @ffmpeg -y -loglevel error -f lavfi -i "anoisesrc=duration={{duration}}" {{output}}
    @gum style --foreground 82 "Created: {{output}}"

# Play audio
# ARGS: input - audio file
audio-play input:
    @gum style --foreground 212 "Playing {{input}}..."
    @ffplay -nodisp -autoexit -loglevel error {{input}}

# Show spectrum visualization (terminal-native)
# ARGS: input - audio file
audio-spectrum input:
    #!/usr/bin/env nu
    let input: string = "{{input}}"
    ^ffmpeg -y -loglevel error -i $input -lavfi "showspectrumpic=s=800x200:color=intensity" .lab/renders/spectrum.png
    ^/Applications/iTerm.app/Contents/Resources/utilities/imgcat .lab/renders/spectrum.png

# Show waveform visualization (terminal-native)
# ARGS: input - audio file
audio-waveform input:
    #!/usr/bin/env nu
    let input: string = "{{input}}"
    ^ffmpeg -y -loglevel error -i $input -lavfi "showwavespic=s=800x200:colors=0x29ADFF|0xFF004D" .lab/renders/waveform.png
    ^/Applications/iTerm.app/Contents/Resources/utilities/imgcat .lab/renders/waveform.png

# Play audio with live ASCII level meter in terminal
# ARGS: input - audio file
audio-viz input:
    #!/usr/bin/env nu
    let input: string = "{{input}}"
    nu Universe/Audio/Bindings/Scripts/default.nu $input

# Render spectrum to image (for terminal preview)
# ARGS: input - audio file, output - image file
audio-spectrum-image input output=".lab/renders/spectrum.png":
    @ffmpeg -y -loglevel error -i {{input}} -lavfi "showspectrumpic=s=1280x640" {{output}}
    @just show {{output}}

# -------------------------------------------------------------------------------
# SIMULATE
# -------------------------------------------------------------------------------

# Run physics simulation via blender
# ARGS: scene - .blend file, frames - frame count
simulate scene frames="60":
    @gum spin --spinner dot --title "Simulating {{frames}} frames..." -- nu {{scripts}}/Simulate/Bindings/Scripts/default.nu '{"action": "run", "scene": "{{scene}}", "frames": {{frames}}}'

# Render single simulation frame
# ARGS: scene - .blend file, frame - frame number
sim-frame scene frame="1":
    @nu {{scripts}}/Simulate/Bindings/Scripts/default.nu '{"action": "render-frame", "scene": "{{scene}}", "frame": {{frame}}, "output": "{{lab}}/renders/frame.png"}'
    @just show {{lab}}/renders/frame.png

# -------------------------------------------------------------------------------
# FABRICATE
# -------------------------------------------------------------------------------

# Export mesh for 3D printing
# ARGS: input - .blend file, format - stl/3mf/obj
fabricate input format="stl":
    @gum spin --spinner dot --title "Exporting {{format}}..." -- nu {{scripts}}/Fabricate/Bindings/Scripts/default.nu '{"action": "export", "input": "{{input}}", "format": "{{format}}"}'

# Slice model for 3D printer
# ARGS: input - STL file, layer - layer height mm, infill - infill %
slice input layer="0.2" infill="20":
    @gum spin --spinner dot --title "Slicing..." -- nu {{scripts}}/Fabricate/Bindings/Scripts/default.nu '{"action": "slice", "input": "{{input}}", "layerHeight": "{{layer}}", "infill": "{{infill}}"}'

# -------------------------------------------------------------------------------
# ASSET
# -------------------------------------------------------------------------------

# Fetch asset from URL
# ARGS: url - source URL, kind - sprite/mesh/audio/texture
asset-fetch url kind="sprite":
    @gum spin --spinner dot --title "Fetching {{kind}}..." -- nu {{scripts}}/Asset/Bindings/Scripts/default.nu '{"action": "fetch", "url": "{{url}}", "kind": "{{kind}}", "storePath": "{{lab}}/assets"}'

# List assets
asset-list:
    @gum style --border normal --padding "0 1" "Assets"
    @nu {{scripts}}/Asset/Bindings/Scripts/default.nu '{"action": "list", "storePath": "{{lab}}/assets"}'

# Catalog all assets with metadata
asset-catalog:
    @nu {{scripts}}/Asset/Bindings/Scripts/default.nu '{"action": "catalog", "storePath": "{{lab}}/assets"}'
