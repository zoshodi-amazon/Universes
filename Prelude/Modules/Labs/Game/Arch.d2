# Game Lab Architecture

direction: down

title: {
  label: Labs/Game - Compositional Design Lab
  shape: text
  style.font-size: 20
}

global: Global Duality {
  style.fill: "#e1f5fe"

  env: Env {
    aggregates: "Universe/*/Options -> ENV vars"
  }

  instances: Instances {
    devshell: "perSystem.devShells.game"
    packages: "perSystem.packages.game-*"
  }

  env -> instances: config
}

universe: Universe {
  style.fill: "#fff3e0"

  core: Core {
    options: "enable, projectDir"
    bindings: "Scripts (init, status)"
  }

  render: Render {
    options: "dimension, resolution, backend, palette"
    bindings: "Scripts (render-2d, render-3d)"
  }

  preview: Preview {
    options: "method, watchExtensions, port"
    bindings: "Scripts (watch, serve)"
  }

  sprite: Sprite {
    options: "width, height, palette, frames"
    bindings: "Scripts (create, sheet, animate)"
  }

  audio: Audio {
    options: "delegates to Labs/Audio"
    bindings: "Scripts (preview, spectrum)"
  }

  simulate: Simulate {
    options: "engine, timeStep, gravity"
    bindings: "Scripts (run)"
  }

  fabricate: Fabricate {
    options: "format, layerHeight, infill"
    bindings: "Scripts (slice, export)"
  }

  asset: Asset {
    options: "backend, storePath, catalogDb"
    bindings: "Scripts (fetch, catalog, list)"
  }
}

universe -> global.instances: exports

pipeline: Design Pipeline {
  style.fill: "#e8f5e9"

  edit: "Edit (nvim)"
  watch: "Watch (watchexec)"
  render: "Render (aseprite/blender)"
  preview: "Preview (chafa/browser)"

  edit -> watch -> render -> preview
  preview -> edit: iterate
}

global.instances -> pipeline: runs
