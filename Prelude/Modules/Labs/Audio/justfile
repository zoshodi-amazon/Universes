# Audio — Metric space observation and transforms via ffmpeg
#
# Naming: [io-]ffmpeg-audio[-subcommand]
#   ffmpeg-audio-*    = pure (observe, analyze — read-only)
#   io-ffmpeg-audio-* = effectful (generate, transform — writes artifacts)

env := "Env"

# Observe via CQT — Constant Q Transform (musical pitch = color, each note distinct)
# ARGS: file - path to audio file
ffmpeg-audio file:
    ffplay -f lavfi \
      "amovie={{file}},volume=4,asplit[a][out1];[a]showcqt=s=400x400:sono_v=64:bar_v=64:sono_g=2:bar_g=1[out0]" \
      -x 400 -y 400 -loop 0 \
      -window_title "CQT — Pitch Field"

# Observe via scrolling spectrogram with rainbow frequency coloring
# ARGS: file - path to audio file
ffmpeg-audio-spectrum file:
    ffplay -f lavfi \
      "amovie={{file}},volume=4,lowpass=f=1500,asplit[a][out1];[a]showspectrum=s=400x400:color=rainbow:slide=scroll:scale=cbrt:saturation=6:fscale=log:start=60:stop=1500:win_func=blackman:overlap=0.95[out0]" \
      -x 400 -y 400 -loop 0 \
      -window_title "Spectrum — Chords"

# Observe Lissajous (harmonic phase structure)
# ARGS: file - path to audio file
ffmpeg-audio-lissajous file:
    ffplay -f lavfi \
      "amovie={{file}},volume=4,aformat=channel_layouts=stereo,asplit[a][out1];[a]avectorscope=s=400x400:m=lissajous_xy:draw=aaline:zoom=5:rc=40:gc=160:bc=255:rf=3:gf=2:bf=4[out0]" \
      -x 400 -y 400 -loop 0 \
      -window_title "Lissajous"

# Observe 3D scope (rotating metric space geometry)
# ARGS: file - path to audio file
ffmpeg-audio-3d file:
    ffplay -f lavfi \
      "amovie={{file}},volume=4,aformat=channel_layouts=stereo,asplit[a][out1];[a]a3dscope=s=400x400:fov=60:roll=0.02:pitch=0.01:yaw=0.03[out0]" \
      -x 400 -y 400 -loop 0 \
      -window_title "3D Scope"

# Acquire audio from URL (youtube, direct link) as wav
# ARGS: url - source URL, name - output filename (without extension)
io-ffmpeg-audio-acquire url name="song":
    nix run nixpkgs#yt-dlp -- -x --audio-format wav --audio-quality 0 -o "{{env}}/{{name}}.%(ext)s" "{{url}}"
    @echo "Acquired: {{env}}/{{name}}.wav"

# Generate melancholic chord progression (Am-F-C-G, piano range, stereo, reverb)
io-ffmpeg-audio-melancholy:
    @ffmpeg -y \
      -f lavfi -i "sine=frequency=440:duration=8:beep_factor=0" \
      -f lavfi -i "sine=frequency=523.25:duration=8:beep_factor=0" \
      -f lavfi -i "sine=frequency=659.25:duration=8:beep_factor=0" \
      -f lavfi -i "sine=frequency=698.46:duration=8:beep_factor=0" \
      -f lavfi -i "sine=frequency=783.99:duration=8:beep_factor=0" \
      -f lavfi -i "sine=frequency=880:duration=8:beep_factor=0" \
      -f lavfi -i "sine=frequency=1046.5:duration=8:beep_factor=0" \
      -filter_complex " \
        [0:a]volume='if(lt(t,2),0.3,if(lt(t,6),0.15,0))':eval=frame[a4]; \
        [1:a]volume='if(lt(t,2),0,if(lt(t,4),0.3,if(lt(t,6),0.3,0)))':eval=frame[c5]; \
        [2:a]volume='if(lt(t,2),0.3,if(lt(t,4),0,if(lt(t,6),0.3,if(lt(t,8),0.3,0))))':eval=frame[e5]; \
        [3:a]volume='if(lt(t,2),0,if(lt(t,4),0.3,0))':eval=frame[f5]; \
        [4:a]volume='if(lt(t,4),0,if(lt(t,6),0,if(lt(t,8),0.3,0)))':eval=frame[g5]; \
        [5:a]volume='if(lt(t,2),0.3,if(lt(t,4),0.3,0))':eval=frame[a5]; \
        [6:a]volume='if(lt(t,4),0,if(lt(t,6),0.2,if(lt(t,8),0,0)))':eval=frame[c5b]; \
        [a4][c5][e5][f5][g5][a5][c5b]amix=inputs=7:normalize=0, \
        aecho=0.4:0.3:40|80:0.2|0.1, \
        volume=3, \
        aformat=channel_layouts=stereo \
      " \
      -c:a pcm_s16le -ar 44100 \
      {{env}}/melancholy.wav 2>/dev/null
    @echo "Generated: {{env}}/melancholy.wav"
