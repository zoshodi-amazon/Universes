{
  "asset": {
    "asset_type": "stock",
    "io_ticker": "AAPL",
    "interval_min": 5,
    "trade_start_min": 570,
    "trade_end_min": 960,
    "holidays": "us_market"
  },
  "run": {
    "seed": 42,
    "name": "pipeline",
    "output_dir": "Env/output",
    "status": "pending",
    "verbose": 0
  },
  "env": {
    "initial_value": 10000.0,
    "fees_pct": 0.1,
    "borrow_rate_pct": 0.0,
    "positions": [0.0, 1.0],
    "broker_mode": "sim",
    "io_broker_key": "sim",
    "stop_loss_pct": -2.0
  },
  "discovery": {
    "io_universe": [],
    "screener": "most_actives",
    "min_adx": 25.0,
    "min_bars": 360,
    "period": "60d",
    "cache_dir": "Env/cache"
  },
  "ingest": {
    "period": "60d",
    "warmup_bars": 28,
    "cache_dir": "Env/cache"
  },
  "feature": {
    "wavelet": "db4",
    "level": 4,
    "threshold_mode": "soft",
    "adx_period": 14,
    "supertrend_period": 10,
    "supertrend_multiplier": 3.0,
    "regime_threshold": 25.0
  },
  "train": {
    "algo": "PPO",
    "n_envs": 1,
    "learning_rate": 0.0003,
    "total_timesteps": 50000,
    "episode_duration_min": 1440,
    "normalize_obs": true,
    "normalize_reward": true
  },
  "eval": {
    "forward_steps_min": 1440,
    "profit_threshold_pct": 0.5
  },
  "pipeline": {
    "stride_min": 1440,
    "train_split_pct": 80.0
  }
}
