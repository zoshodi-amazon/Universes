{
  "home": {
    "darwin": { "enable": true, "username": "zoshodi", "homeDirectory": "/Users/zoshodi", "stateVersion": "24.05" },
    "cloudDev": { "enable": true, "username": "zoshodi", "homeDirectory": "/home/zoshodi", "stateVersion": "24.05" },
    "cloudNix": { "enable": false, "username": "zoshodi", "homeDirectory": "/home/zoshodi", "stateVersion": "24.05" },
    "nixos": { "enable": true, "username": "zoshodi", "homeDirectory": "/home/zoshodi", "stateVersion": "24.05" }
  },
  "corePackages": [
    "just", "gum", "ripgrep", "fd", "jq", "yq", "bat", "eza", "fzf",
    "nil", "nixfmt-rfc-style", "nh", "nix-output-monitor",
    "podman", "qemu", "d2", "graphviz", "plantuml",
    "f3d", "openscad", "typst", "zathura", "glow",
    "inkscape", "ffmpeg", "raylib", "entr", "lazygit", "gh", "tree",
    "opencode", "ollama", "ast-grep"
  ],
  "machines": {
    "sovereignty": {
      "hostname": "sovereignty", "arch": "x86_64", "format": "iso",
      "disk": { "layout": "standard", "device": "/dev/sda", "filesystem": "ext4", "encryption": "none", "remoteUnlock": false, "swapSize": "none", "persistLabel": "NIXOS_PERSIST" },
      "hardware": { "enable": false, "profile": "generic", "gpu": "none", "firmware": true, "audio": "none", "bluetooth": false },
      "persistence": { "strategy": "impermanent", "device": "/dev/disk/by-label/NIXOS_PERSIST", "paths": ["/var/log", "/var/lib/nixos", "/etc/NetworkManager/system-connections"] },
      "users": [{ "name": "zoshodi", "groups": ["wheel", "networkmanager"], "initialPassword": "" }]
    },
    "nixos-workstation": {
      "hostname": "nixos-workstation", "arch": "x86_64", "format": "vm",
      "disk": { "layout": "standard", "device": "/dev/sda", "filesystem": "ext4", "encryption": "none", "remoteUnlock": false, "swapSize": "none", "persistLabel": "" },
      "hardware": { "enable": true, "profile": "desktop", "gpu": "none", "firmware": true, "audio": "pipewire", "bluetooth": true },
      "persistence": { "strategy": "persistent", "device": "", "paths": [] },
      "users": [{ "name": "zoshodi", "groups": ["wheel", "networkmanager"], "initialPassword": "" }]
    },
    "test-vm": {
      "hostname": "test-vm", "arch": "x86_64", "format": "microvm",
      "disk": { "layout": "none", "device": "/dev/sda", "filesystem": "ext4", "encryption": "none", "remoteUnlock": false, "swapSize": "none", "persistLabel": "" },
      "hardware": { "enable": false, "profile": "vm", "gpu": "none", "firmware": false, "audio": "none", "bluetooth": false },
      "persistence": { "strategy": "ephemeral", "device": "", "paths": ["/var/log", "/var/lib/nixos", "/etc/NetworkManager/system-connections"] },
      "users": [{ "name": "test", "groups": ["wheel"], "initialPassword": "" }]
    }
  },
  "microvm": { "mem": 2048, "vcpu": 2, "hypervisor": "qemu" }
}
