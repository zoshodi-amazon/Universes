{
  "asset": {
    "index_class": "stock",
    "io_ticker": "AAPL",
    "interval_min": 5,
    "trade_start_min": 570,
    "trade_end_min": 960,
    "holidays": "us_market"
  },
  "run": {
    "seed": 42,
    "name": "solve",
    "verbose": 0
  },
  "store": {
    "db_url": "sqlite:///store/.rl.db",
    "blob_dir": "store/blobs",
    "session_id": "00000000",
    "phase": "solve",
    "docs_dir": "store/docs"
  },
  "env": {
    "initial_value": 10000.0,
    "fees_pct": 0.1,
    "borrow_rate_pct": 0.0,
    "positions": [-1.0, 0.0, 1.0],
    "execution_mode": "sim",
    "io_execution_key": "sim"
  },
  "solve": {
    "solver": "PPO",
    "n_parallel": 1,
    "learning_rate": 0.0003,
    "budget": 50000,
    "horizon_min": 1440,
    "normalize_input": true,
    "normalize_signal": true
  }
}
