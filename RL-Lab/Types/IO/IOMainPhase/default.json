{
  "asset": {
    "asset_type": "stock",
    "io_ticker": "AAPL",
    "interval_min": 5,
    "trade_start_min": 570,
    "trade_end_min": 960,
    "holidays": "us_market"
  },
  "run": {
    "seed": 42,
    "name": "main",
    "verbose": 0
  },
  "env": {
    "initial_value": 10000.0,
    "fees_pct": 0.1,
    "borrow_rate_pct": 0.0,
    "positions": [-1.0, 0.0, 1.0],
    "broker_mode": "sim",
    "io_broker_key": "sim"
  },
  "risk": {
    "stop_loss_pct": -2.0,
    "profit_threshold_pct": 0.5,
    "max_drawdown_pct": -5.0
  },
  "main": {
    "stride_min": 1440,
    "train_split_pct": 80.0,
    "optimize": false,
    "optimize_config": {
      "n_trials": 20,
      "n_parallel": 1,
      "objective_metric": "win_rate_pct",
      "search_space_lr_min": 0.00001,
      "search_space_lr_max": 0.01,
      "search_space_timesteps_min": 10000,
      "search_space_timesteps_max": 200000
    }
  },
  "store": {
    "db_url": "sqlite:///store/.rl.db",
    "blob_dir": "store/blobs",
    "run_id": "00000000",
    "phase": "pipeline",
    "docs_dir": "store/docs"
  }
}
