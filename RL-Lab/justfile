# RL Trading Sandbox -- justfile
# Every command is a classified morphism: ana- (observe), cata- (produce), hylo- (composite).
# 6 cata- phases (Types/IO), 7 ana- observers (CoTypes/CoIO), 1 hylo- composite, 1 ana- cross-cutting.
# No ad-hoc commands. Every recipe maps to exactly one IO or CoIO executor.

# ── cata- (Catamorphism / Production) ─────────────────────────────────

# Phase 1 (BEC): Discovery — find trending assets via screener + ADX filter
cata-discover *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IODiscoveryPhase.default {{ARGS}}

# Phase 2 (Crystalline): Ingest — download + cache OHLCV data
cata-ingest *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOIngestPhase.default {{ARGS}}

# Phase 3 (Liquid Crystal): Feature — wavelet denoise + technical indicators
cata-feature *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOFeaturePhase.default {{ARGS}}

# Phase 4 (Liquid): Train — RL model training with SB3
cata-train *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOTrainPhase.default {{ARGS}}

# Phase 5 (Gas): Eval — out-of-sample backtesting
cata-eval *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOEvalPhase.default {{ARGS}}

# Phase 6 (Plasma): Serve — live bar-by-bar serving with broker execution
cata-serve *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOServePhase.default {{ARGS}}

# ── hylo- (Hylomorphism / Composite) ─────────────────────────────────

# Phase 7 (QGP): Main — full pipeline with optional Optuna optimization
# Usage: just hylo-main                           (standard walk-forward)
# Usage: just hylo-main --main.optimize true      (Optuna hyperparameter search)
hylo-main *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOMainPhase.default {{ARGS}}

# ── ana- (Anamorphism / Observation) ──────────────────────────────────

# Phase 1 observer: probe last DiscoveryProductOutput from StoreMonad
ana-discover *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIODiscoveryPhase.default {{ARGS}}

# Phase 2 observer: probe last IngestProductOutput
ana-ingest *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOIngestPhase.default {{ARGS}}

# Phase 3 observer: probe FeatureProductOutput geometry stats
ana-feature *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOFeaturePhase.default {{ARGS}}

# Phase 4 observer: probe TrainProductOutput learning curves
ana-train *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOTrainPhase.default {{ARGS}}

# Phase 5 observer: probe EvalProductOutput return/drawdown
# Usage: just ana-eval --eval.launch_renderer true  (launches Flask render dashboard)
ana-eval *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOEvalPhase.default {{ARGS}}

# Phase 6 observer: probe ServeProductOutput broker/audit
ana-serve *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOServePhase.default {{ARGS}}

# Phase 7 observer: probe MainProductOutput + validate type system + optional Rerun visualization
# Usage: just ana-main                              (artifact probe + validation)
# Usage: just ana-main --main.visualize true        (also log to Rerun)
ana-main *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOMainPhase.default {{ARGS}}

# Cross-cutting: system health check — imports, field counts, JSON fidelity, roundtrip closure
# Delegates to ana-main with all validation flags enabled, no artifact probe
ana-check:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOMainPhase.default --main.validate_imports true --main.validate_fields true --main.validate_json true --main.visualize false
