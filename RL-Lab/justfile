# RL Trading Sandbox -- justfile
# Every command is a classified morphism: ana- (observe), cata- (produce), hylo- (composite).
# 6 cata- phases (Types/IO), 7 ana- observers (CoTypes/CoIO), 1 hylo- composite, 1 ana- cross-cutting.
# No ad-hoc commands. Every recipe maps to exactly one IO or CoIO executor.

# ── cata- (Catamorphism / Production) ─────────────────────────────────

# Phase 1 (BEC): Discovery — find trending assets via screener + ADX filter
cata-discover *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IODiscoveryPhase.default {{ARGS}}

# Phase 2 (Crystalline): Ingest — download + cache OHLCV data
cata-ingest *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOIngestPhase.default {{ARGS}}

# Phase 3 (Liquid Crystal): Transform — wavelet denoise + technical indicators
cata-transform *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOTransformPhase.default {{ARGS}}

# Phase 4 (Liquid): Solve — RL model solving with SB3
cata-solve *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOSolvePhase.default {{ARGS}}

# Phase 5 (Gas): Eval — out-of-sample backtesting
cata-eval *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOEvalPhase.default {{ARGS}}

# Phase 6 (Plasma): Project — live bar-by-bar projection with broker execution
cata-project *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOProjectPhase.default {{ARGS}}

# ── hylo- (Hylomorphism / Composite) ─────────────────────────────────

# Phase 7 (QGP): Compose — full pipeline with optional Optuna search
# Usage: just hylo-compose                           (standard walk-forward)
# Usage: just hylo-compose --compose.search true     (Optuna hyperparameter search)
hylo-compose *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOComposePhase.default {{ARGS}}

# ── ana- (Anamorphism / Observation) ──────────────────────────────────

# Phase 1 observer: probe last DiscoveryProductOutput from StoreMonad
ana-discover *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIODiscoveryPhase.default {{ARGS}}

# Phase 2 observer: probe last IngestProductOutput
ana-ingest *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOIngestPhase.default {{ARGS}}

# Phase 3 observer: probe TransformProductOutput geometry stats
ana-transform *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOTransformPhase.default {{ARGS}}

# Phase 4 observer: probe SolveProductOutput learning curves
ana-solve *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOSolvePhase.default {{ARGS}}

# Phase 5 observer: probe EvalProductOutput return/drawdown
# Usage: just ana-eval --eval.launch_renderer true  (launches Flask render dashboard)
ana-eval *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOEvalPhase.default {{ARGS}}

# Phase 6 observer: probe ProjectProductOutput broker/audit
ana-project *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOProjectPhase.default {{ARGS}}

# Phase 7 observer: probe ComposeProductOutput + validate type system + optional Rerun visualization
# Usage: just ana-compose                              (artifact probe + validation)
# Usage: just ana-compose --compose.visualize true     (also log to Rerun)
ana-compose *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOComposePhase.default {{ARGS}}

# Cross-cutting: system health check — imports, field counts, JSON fidelity, roundtrip closure
# Delegates to ana-compose with all validation flags enabled, no artifact probe
ana-check:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.CoIO.CoIOComposePhase.default --compose.validate_imports true --compose.validate_fields true --compose.validate_json true --compose.visualize false
