# ===============================================================================
# RL Trading Sandbox -- justfile
# ===============================================================================
#
# Every command is a classified morphism (6-functor formalism):
#
#   ana-{cmd}   — anamorphism  — coalgebraic observation (f*, f!, Hom)
#   cata-{cmd}  — catamorphism — algebraic production (f*, f!)
#   hylo-{cmd}  — hylomorphism — tensor composite: ana then cata (⊗)
#
# Phase chain:
#   Discovery → Ingest → Feature → Train → Eval → Serve → Main
#   (Unit/⊤)    (ADT)    (Indexed)  (A→B)   (A×B)  (M A)    (IO)
#
# 1:1 with Types/IO (7 phases). Each phase has own BaseSettings + default.json.
# CLI args override.
#
# ===============================================================================

default:
    @just --list

# ===============================================================================
# cata- (Catamorphism) — Algebraic productions → Types/
# ===============================================================================

# f* pushforward -- IO/Discovery: find trending assets via screener + ADX filter
cata-discover *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IODiscoveryPhase.default {{ARGS}}

# f* pushforward -- IO/Ingest: download + cache OHLCV data
cata-ingest *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOIngestPhase.default {{ARGS}}

# f* pushforward -- IO/Feature: wavelet denoise + technical indicators
cata-feature *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOFeaturePhase.default {{ARGS}}

# f! shriek push -- IO/Train: RL model training with SB3
cata-train *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOTrainPhase.default {{ARGS}}

# f! shriek push -- IO/Eval: out-of-sample backtesting
cata-eval *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOEvalPhase.default {{ARGS}}

# f! shriek push -- IO/Serve: live bar-by-bar serving with broker execution
cata-serve *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOServePhase.default {{ARGS}}

# ===============================================================================
# hylo- (Hylomorphism) — Tensor composites → Types/ ⊗ CoTypes/
# ===============================================================================

# ⊗ tensor -- IO/Main: full pipeline with optional Optuna optimization
# Usage: just hylo-main                           (standard walk-forward)
# Usage: just hylo-main --main.optimize true      (Optuna hyperparameter search)
hylo-main *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m Types.IO.IOMainPhase.default {{ARGS}}

# ===============================================================================
# ana- (Anamorphism) — Coalgebraic observations → CoTypes/
# ===============================================================================

# f* pullback -- CoIO/Render: visualize results via gym-trading-env Flask app
# Usage: just ana-render <run_id>    (e.g. just ana-render a1b2c3d4)
ana-render run_id:
    .venv/bin/python -W ignore::ResourceWarning -c "from gym_trading_env.renderer import Renderer; Renderer(render_logs_dir=\"store/blobs/{{run_id}}/render_logs\").run()"

# f* pullback -- CoIO/Tail: tail OpenCode SSE event stream
# Usage: just ana-tail
# Usage: just ana-tail --tail.port 4096 --tail.filter_kinds '["tool","file"]'
ana-tail *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.IO.IOTailPhase.default {{ARGS}}

# f* pullback -- CoIO/Visualize: Rerun multi-modal visualization of run outputs
# Usage: just ana-visualize
# Usage: just ana-visualize --visualize.include_features true
ana-visualize *ARGS:
    .venv/bin/python -W ignore::ResourceWarning -m CoTypes.IO.IOVisualizePhase.default {{ARGS}}
